{
  "name": "fit-tnt",
  "version": "10.0.0",
  "description": "TNT - A Least Squares Iterative Solver.",
  "main": "./lib/index.js",
  "module": "./lib-esm/index.js",
  "types": "./lib/index.d.ts",
  "sideEffects": false,
  "files": [
    "src",
    "lib",
    "lib-esm"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib lib-esm",
    "eslint": "eslint src",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "test": "npm run test-only && npm run eslint && npm run prettier && npm run check-types",
    "test-only": "vitest --run --coverage",
    "test-watch": "vitest",
    "tsc": "npm run clean && npm run tsc-cjs && npm run tsc-esm",
    "tsc-cjs": "tsc --project tsconfig.cjs.json",
    "tsc-esm": "tsc --project tsconfig.esm.json",
    "bench": "tsx ./benchmark/versus_pseudo.ts",
    "profile": "tsx --cpu-prof ./benchmark/versus_pseudo.ts "
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newseru/fit-tnt.git"
  },
  "keywords": [
    "least squares",
    "unconstrained optimization",
    "linear regression",
    "iterative methods"
  ],
  "author": "Santiago Miranda",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/newseru/fit-tnt/issues"
  },
  "homepage": "https://github.com/newseru/fit-tnt#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-jsdoc": "^63.0.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "ml-matrix": "^6.12.2"
  }
}
